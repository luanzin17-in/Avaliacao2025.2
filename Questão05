 public static int contarMaioresQue(Pessoa[] v, int qtd, int idadeMinima) {

        int cont = 0;
        for (int i = 0; i < qtd; i++) {
            if (v[i].idade >= idadeMinima) {
                cont++;
            }
        }

        return cont;
    }
